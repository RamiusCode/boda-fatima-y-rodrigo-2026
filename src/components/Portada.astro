---
// Portada.astro
---

<section
    id="portada-sobre"
    class="fixed inset-0 w-full h-[100dvh] z-50 flex flex-col items-center justify-start overflow-hidden bg-white px-6 py-8"
    style="background-image: url('/imagenes/BlancoTextura.png'); background-repeat: repeat; background-size: contain;"
>
    <!-- ═══════════════ FLORES DECORATIVAS (flor.png) ═══════════════ -->
    <!-- Esquina superior izquierda -->
    <img
        src="/imagenes/flor.png"
        alt=""
        aria-hidden="true"
        class="pointer-events-none select-none absolute top-0 left-0 w-64 sm:w-80 md:w-96 lg:w-[28rem] z-0"
    />
    <!-- Esquina inferior derecha (espejo doble) -->
    <img
        src="/imagenes/flor.png"
        alt=""
        aria-hidden="true"
        class="pointer-events-none select-none absolute bottom-0 right-0 w-60 sm:w-72 md:w-80 lg:w-96 z-0"
        style="transform: scale(-1, -1);"
    />

    <!-- ═══════════════ CONTENIDO CENTRAL ═══════════════ -->
    <!-- TÍTULO SUPERIOR -->
    <h1
        id="portada-titulo"
        class="absolute top-32 sm:top-36 md:top-40 left-1/2 -translate-x-1/2 z-10 w-full text-center font-crimson text-xl sm:text-2xl md:text-3xl text-[#557A99] tracking-normal uppercase"
    >
        Nuestra Boda
    </h1>

    <div
        class="relative z-10 flex flex-col items-center justify-start text-center w-full max-w-md mx-auto gap-4 sm:gap-6 pt-44 sm:pt-48 md:pt-52"
    >
        <!-- NOMBRES -->
        <h2
            id="portada-nombres"
            class="font-great-vibes text-5xl sm:text-6xl md:text-7xl text-[#c9a961] leading-tight"
        >
            Fátima <span class="text-3xl sm:text-4xl md:text-5xl align-middle">&amp;</span> Rodrigo
        </h2>

        <!-- FECHA -->
        <p
            id="portada-fecha"
            class="font-crimson text-base sm:text-lg md:text-xl text-[#557A99] tracking-[0.3em] uppercase"
        >
            29 · Agosto · 2026
        </p>

        <!-- SOBRE CENTRAL (sobre.png) - BOTÓN PARA ABRIR -->
        <button
            id="btn-sobre"
            class="relative cursor-pointer transition-transform duration-300 hover:scale-105 active:scale-95 focus:outline-none mt-2"
            aria-label="Abrir invitación"
        >
            <img
                src="/imagenes/sobre.png"
                alt="Sobre invitación"
                class="w-56 sm:w-72 md:w-80 h-auto drop-shadow-xl rounded-md"
            />
        </button>

        <!-- TEXTO CLICK PARA ABRIR -->
        <div
            id="portada-click"
            class="mt-6 sm:mt-8 text-[#557A99]"
        >
            <span
                class="font-crimson text-base sm:text-lg md:text-xl tracking-[0.2em] uppercase"
            >
                Click en el sobre para abrir la invitación
            </span>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const btnSobre = document.getElementById("btn-sobre");
        const portada = document.getElementById("portada-sobre");

        // Animación de entrada del sobre
        gsap.from("#btn-sobre", {
            scale: 0.85,
            opacity: 0,
            duration: 1.4,
            ease: "elastic.out(1, 0.6)",
            delay: 0.4,
        });

        // Respiración suave del sobre
        gsap.to("#btn-sobre", {
            scale: 1.04,
            duration: 2.4,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
        });

        btnSobre?.addEventListener("click", () => {
            // Crear y reproducir música automáticamente
            const audio = new Audio("/musica/melodia.mp3");
            audio.loop = true;
            audio.volume = 0.5;
            audio.play().catch((error: any) => {
                console.log("Error al reproducir audio:", error);
            });

            // Guardar en window para que NombresFlores pueda controlarlo
            (window as any).audioGlobal = audio;
            (window as any).estaReproduciendoGlobal = true;

            // Actualizar iconos inmediatamente
            setTimeout(() => {
                const iconoPlay = document.getElementById("icono-play");
                const iconoPause = document.getElementById("icono-pause");

                if (iconoPlay && iconoPause) {
                    iconoPlay.classList.add("hidden");
                    iconoPause.classList.remove("hidden");
                    console.log("✅ Iconos actualizados a PAUSE");
                }
            }, 100);

            gsap.to(portada, {
                opacity: 0,
                duration: 0.8,
                ease: "power2.out",
                onStart: () => {
                    document.body.style.overflow = "auto";
                },
                onComplete: () => {
                    portada?.remove(); // Eliminar completamente del DOM
                },
            });
        });
    });
</script>

<style>
    body {
        overflow: hidden;
    }
</style>
