<!-- ═══════════════════════════════════════════════════════════ --><!-- 📖 SECCIÓN: CITA BÍBLICA                                    --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-6 sm:py-10" id="seccion-cita">
    <div class="max-w-6xl mx-auto px-10 sm:px-16 lg:px-24">
        <div class="flex flex-col items-center text-center" id="cita-container">
            <p
                class="font-great-vibes text-2xl sm:text-3xl md:text-4xl text-[#557A99] leading-relaxed"
                id="cita-texto"
            >
                &ldquo;Hay momentos en la vida que son especiales por sí solos, pero sin lugar a dudas, el hecho de que Dios nos haya permitido compartir junto a ustedes nuestro feliz comienzo, lo convierte en un día inolvidable&rdquo;
            </p>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.fromTo(
            "#cita-texto",
            { opacity: 0, y: 20 },
            {
                opacity: 1,
                y: 0,
                duration: 1.4,
                ease: "sine.out",
                scrollTrigger: {
                    trigger: "#cita-container",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        gsap.fromTo(
            "#cita-referencia",
            { opacity: 0, y: 10 },
            {
                opacity: 1,
                y: 0,
                duration: 1,
                ease: "sine.out",
                delay: 0.4,
                scrollTrigger: {
                    trigger: "#cita-container",
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    });
</script>
