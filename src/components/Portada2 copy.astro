---
// Portada2.astro
interface Props {
    nombreInvitado?: string;
    numeroPases?: number;
}
// 👇 Coloca aquí el nombre del invitado y el número de pases
// (o pásalos como prop: <Portada2 nombreInvitado="Juan Pérez" numeroPases={2} />)
const { nombreInvitado = "Familia Pérez García", numeroPases = 2 } =
    Astro.props;
---

<section
    id="portada-sobre"
    class="fixed inset-0 w-full h-[100dvh] z-50 flex flex-col items-center justify-start overflow-hidden bg-white px-6 py-8"
    style="background-image: url('/imagenes/BlancoTextura.png'); background-repeat: repeat; background-size: contain;"
>
    <!-- ═══════════════ FLORES DECORATIVAS (flor.png) ═══════════════ -->
    <!-- Esquina superior izquierda -->
    <img
        src="/imagenes/flor.png"
        alt=""
        aria-hidden="true"
        class="pointer-events-none select-none absolute top-0 left-0 w-52 sm:w-64 md:w-80 lg:w-96 z-0"
    />
    <!-- Esquina inferior derecha (espejo doble) -->
    <img
        src="/imagenes/flor.png"
        alt=""
        aria-hidden="true"
        class="pointer-events-none select-none absolute bottom-0 right-0 w-52 sm:w-64 md:w-80 lg:w-96 z-0"
        style="transform: scale(-1, -1);"
    />

    <!-- ═══════════════ CONTENIDO CENTRAL ═══════════════ -->
    <div
        class="relative z-10 flex flex-col items-center justify-center text-center w-full max-w-md mx-auto h-full gap-6 sm:gap-8 py-4"
    >
        <!-- ── GRUPO SUPERIOR: TÍTULO, NOMBRES, INVITADO Y PASES ── -->
        <div class="flex flex-col items-center gap-1.5 sm:gap-2.5">
            <!-- TÍTULO SUPERIOR -->
            <h1
                id="portada-titulo"
                class="font-crimson text-xl sm:text-2xl md:text-3xl text-[#557A99] tracking-normal uppercase"
            >
                Nuestra Boda
            </h1>

            <!-- NOMBRES -->
            <h2
                id="portada-nombres"
                class="font-great-vibes text-4xl sm:text-5xl md:text-6xl text-[#c9a961] leading-tight"
            >
                Fátima <span class="text-2xl sm:text-3xl md:text-4xl align-middle">&amp;</span> Rodrigo
            </h2>

            <!-- FECHA -->
            <p
                id="portada-fecha"
                class="font-crimson text-base sm:text-lg md:text-xl text-[#557A99] tracking-[0.3em] uppercase"
            >
                29 · Agosto · 2026
            </p>

            <!-- SEPARADOR DECORATIVO -->
            <div class="flex items-center justify-center gap-3 mt-4 sm:mt-5">
                <span class="block w-12 sm:w-16 h-px bg-[#c9a961]/70"></span>
                <span class="text-[#c9a961] text-lg leading-none">&#10086;</span>
                <span class="block w-12 sm:w-16 h-px bg-[#c9a961]/70"></span>
            </div>

            <!-- NOMBRE DEL INVITADO (marco dorado) -->
            <div class="flex flex-col items-center">
                <span
                    class="font-crimson text-[0.7rem] sm:text-xs tracking-[0.3em] uppercase text-[#557A99] mb-1.5"
                >
                    Invitación especial para
                </span>
                <div
                    class="relative px-6 py-2 sm:px-8 sm:py-2.5 border-2 border-[#c9a961] rounded-lg bg-white/40 shadow-sm"
                >
                    <!-- esquinas decorativas -->
                    <span class="absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-[#c9a961]"></span>
                    <span class="absolute -top-1 -right-1 w-3 h-3 border-t-2 border-r-2 border-[#c9a961]"></span>
                    <span class="absolute -bottom-1 -left-1 w-3 h-3 border-b-2 border-l-2 border-[#c9a961]"></span>
                    <span class="absolute -bottom-1 -right-1 w-3 h-3 border-b-2 border-r-2 border-[#c9a961]"></span>
                    <p
                        id="portada-invitado"
                        class="font-great-vibes text-2xl sm:text-3xl md:text-4xl text-[#c9a961] leading-none whitespace-nowrap"
                    >
                        {nombreInvitado}
                    </p>
                </div>
            </div>

            <!-- PASES / LUGARES RESERVADOS -->
            <div class="flex flex-col items-center">
                <span
                    class="font-crimson text-[0.7rem] sm:text-xs tracking-[0.3em] uppercase text-[#557A99]"
                >
                    Hemos reservado
                </span>
                <span
                    class="font-crimson font-semibold text-3xl sm:text-4xl text-[#c9a961] leading-none my-0.5"
                >
                    {numeroPases}
                </span>
                <span
                    class="font-crimson text-[0.7rem] sm:text-xs tracking-[0.3em] uppercase text-[#557A99]"
                >
                    {numeroPases === 1 ? "Lugar en su honor" : "Lugares en su honor"}
                </span>
            </div>
        </div>

        <!-- ── SOBRE CENTRAL (sobre.png) - BOTÓN PARA ABRIR ── -->
        <button
            id="btn-sobre"
            class="relative cursor-pointer transition-transform duration-300 hover:scale-105 active:scale-95 focus:outline-none"
            aria-label="Abrir invitación"
        >
            <img
                src="/imagenes/sobre.png"
                alt="Sobre invitación"
                class="w-52 sm:w-64 md:w-72 h-auto drop-shadow-xl rounded-md"
            />
        </button>

        <!-- ── TEXTO CLICK PARA ABRIR ── -->
        <div
            id="portada-click"
            class="flex flex-col items-center gap-2 text-[#557A99]"
        >
            <span class="block w-20 sm:w-24 h-px bg-[#557A99]/50"></span>
            <span
                class="font-crimson text-sm sm:text-base md:text-lg tracking-normal uppercase leading-snug"
            >
                Click en el sobre para <br /> abrir la invitación
            </span>
            <span class="block w-20 sm:w-24 h-px bg-[#557A99]/50"></span>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const btnSobre = document.getElementById("btn-sobre");
        const portada = document.getElementById("portada-sobre");

        // Animación de entrada del sobre
        gsap.from("#btn-sobre", {
            scale: 0.85,
            opacity: 0,
            duration: 1.4,
            ease: "elastic.out(1, 0.6)",
            delay: 0.4,
        });

        // Respiración suave del sobre
        gsap.to("#btn-sobre", {
            scale: 1.04,
            duration: 2.4,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
        });

        btnSobre?.addEventListener("click", () => {
            // Crear y reproducir música automáticamente
            const audio = new Audio("/musica/melodia.mp3");
            audio.loop = true;
            audio.volume = 0.5;
            audio.play().catch((error: any) => {
                console.log("Error al reproducir audio:", error);
            });

            // Guardar en window para que NombresFlores pueda controlarlo
            (window as any).audioGlobal = audio;
            (window as any).estaReproduciendoGlobal = true;

            // Actualizar iconos inmediatamente
            setTimeout(() => {
                const iconoPlay = document.getElementById("icono-play");
                const iconoPause = document.getElementById("icono-pause");

                if (iconoPlay && iconoPause) {
                    iconoPlay.classList.add("hidden");
                    iconoPause.classList.remove("hidden");
                    console.log("✅ Iconos actualizados a PAUSE");
                }
            }, 100);

            gsap.to(portada, {
                opacity: 0,
                duration: 0.8,
                ease: "power2.out",
                onStart: () => {
                    document.body.style.overflow = "auto";
                },
                onComplete: () => {
                    portada?.remove(); // Eliminar completamente del DOM
                },
            });
        });
    });
</script>

<style>
    body {
        overflow: hidden;
    }
</style>
